Algoritmo ejercicio_6
	
	Escribir "ingrese la cantidad de segundos totales"
	Leer segundos_totales
	
	segundos_a_dias=segundos_totales/24/60/60
	segundos_a_horas=segundos_totales/60/60
	segundos_a_minutos=segundos_totales/60
	
	Escribir "la cantidad de dias es: ", segundos_a_dias
	Escribir "la cantidad de horas es: ", segundos_a_horas
	Escribir "la cantidad de minutos es: ", segundos_a_minutos
	
FinAlgoritmo
